# Production Environment Variables
# Copy this file to .env.prod and fill in the actual values

# Database Configuration
DB_USERNAME=your_db_username
DB_PASSWORD=your_secure_db_password

# VNPay Configuration (Get these from VNPay)
VNPAY_TMN_CODE=your_production_tmn_code
VNPAY_HASH_SECRET=your_production_hash_secret

# Application Configuration
APP_BASE_URL=https://yourdomain.com

# JWT Configuration
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_at_least_256_bits

# Optional: Additional security
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
